# pytorch-agent environment config
# Copy to .env and fill in values. Sourced by scripts/cron.sh automatically.

# REQUIRED: private review fork (e.g. "yourorg/pytorch")
PRIVATE_REVIEW_REPO=

# REQUIRED: GitHub tokens
GH_TOKEN=""  # Token with write access to UPSTREAM_ISSUE_REPO
REVIEW_GH_TOKEN=""  # Token with write access to PRIVATE_REVIEW_REPO

# Optional overrides (defaults shown)
# UPSTREAM_ISSUE_REPO=intel/torch-xpu-ops
# PUBLIC_TARGET_REPO=pytorch/pytorch
# PYTORCH_DIR=$HOME/pytorch
# AGENT_BACKEND=opencode
# OPENCODE_CMD=opencode
