# ---- OOB Performance Analysis environment ----
# Copy this file to .env and fill in the values:
#   cp .env.example .env && chmod 600 .env
# Then source it before running any scenario:
#   set -a && source .env && set +a

# --- Jenkins ---
# Base URL of the Jenkins server (no trailing slash)
# JENKINS_URL=https://your-jenkins-server.example.com
# Jenkins API token for triggering profiling builds (optional, some servers allow anonymous)
# JENKINS_API_TOKEN=

# --- Tokens ---
# Hugging Face Hub token (for downloading gated models)
# HF_TOKEN=
# HTTP proxy for model downloads (used by Jenkins and LLM profiling)
# NODE_PROXY=

# --- Paths ---
# Conda activation command (platform-specific)
# CONDA_ACTIVATE="source /path/to/conda.sh && conda activate myenv"
# Working directory (repo root of the OOB benchmark checkout)
# OOB_REPO_ROOT=

# --- Result data directories (per-platform, per-dataset) ---
# OOB_RESULTS_INFERENCE_B580=
# OOB_RESULTS_INFERENCE_4080S=
# OOB_RESULTS_INFERENCE_B70=
# OOB_RESULTS_TRAINING_B580=
# OOB_RESULTS_TRAINING_4080S=
# OOB_RESULTS_TRAINING_B70=
# OOB_RESULTS_COMPILE_B580=
# OOB_RESULTS_COMPILE_4080S=
# OOB_RESULTS_COMPILE_B70=
# OOB_RESULTS_LLM_4080S=
# OOB_RESULTS_LLM_B70=
