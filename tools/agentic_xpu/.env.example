# ---- Shared environment for all agentic_xpu scenarios ----
# Copy this file to .env and fill in the values:
#   cp .env.example .env && chmod 600 .env
# Then source it before running any scenario:
#   set -a && source tools/agentic_xpu/.env && set +a

# --- Tokens ---
# GitHub token with read/write repo access (issues, PRs, status checks)
GITHUB_TOKEN=YOUR_TOKEN_HERE
ISSUE_REPO=<target-repo>/intel/torch-xpu-ops

# --- Repository config (issue_handler) ---
# REQUIRED for issue_handler: private review fork (e.g. "yourorg/pytorch")
# PRIVATE_REVIEW_REPO=""
# Optional overrides (defaults shown):
# PUBLIC_TARGET_REPO=pytorch/pytorch
# PYTORCH_DIR=$HOME/pytorch

# AGENT_BACKEND=opencode
# OPENCODE_CMD=opencode

# --- Repository config (xpu_alignment) ---
# Target repo for xpu-alignment issue filing (default: intel/torch-xpu-ops)
# XPU_ALIGNMENT_ISSUE_REPO=intel/torch-xpu-ops

# --- Python environment activation script ---
# Path to a shell script that activates your Python environment.
# Examples:
#   conda:  ~/anaconda3/etc/profile.d/conda.sh && conda activate myenv
#   venv:   .venv/bin/activate
# PYTHON_ENV_ACTIVATE=~/anaconda3/etc/profile.d/conda.sh && conda activate myenv

# --- Build environment (source before building PyTorch) ---
# export TORCH_XPU_ARCH_LIST=pvc
# export USE_XPU=1
# export USE_CUDA=0
# source ~/intel/oneapi/compiler/latest/env/vars.sh
