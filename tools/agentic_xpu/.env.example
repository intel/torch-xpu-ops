# GitHub token with read/write repo access, used for issue/PR creation and status tracking
GITHUB_TOKEN=ghp_YOUR_TOKEN

# Path to opencode binary (default: opencode in $PATH)
# OPENCODE_BIN=~/.opencode/bin/opencode

# Workspace root (default: auto-detected via git)
# WORKSPACE=/path/to/torch-xpu-ops

# Target repo for xpu-alignment issue filing (default: intel/torch-xpu-ops)
# XPU_ALIGNMENT_ISSUE_REPO=intel/torch-xpu-ops
